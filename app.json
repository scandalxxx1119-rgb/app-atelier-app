{
  "expo": {
    "name": "App Atelier",
    "slug": "app-atelier-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "appatelier",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appatelier.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.appatelier.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "アプリのアイコンや画像を選択するためにフォトライブラリへのアクセスが必要です。"
        }
      ],
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b0e43f0-a513-4433-b622-12b79a50c7fa"
      }
    }
  }
}
